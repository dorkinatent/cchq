# Copy to .env.local and fill in.
# Most of these come from a local Supabase stack — run `supabase start`
# in this repo, then `supabase status` to print the generated values.

# Postgres connection string (Supabase exposes this at its DB port).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres

# Supabase URLs — keep NEXT_PUBLIC_SUPABASE_URL matching your `supabase status` API URL.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331

# From `supabase status` → "anon key" and "service_role key".
# NEVER commit real values; keep them in .env.local (which is gitignored).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Controls the .local mDNS hostname (e.g. LOCAL_NAME=myname → http://myname.local:3000).
# Defaults to "cchq" if not set.
LOCAL_NAME=cchq
